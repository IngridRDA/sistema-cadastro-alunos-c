# Arquivo .gitignore para projetos em C
# Ignora arquivos compilados, temporários e configurações locais da IDE.

# ==========================
# Arquivos compilados
# ==========================
*.exe
*.out
*.o
*.obj
*.a
*.so
*.dll
*.lib

# ==========================
# Pastas de compilação
# ==========================
build/
bin/
Debug/
Release/

# ==========================
# Arquivos temporários
# ==========================
*.log
*.tmp
*.temp

# ==========================
# Configurações do VS Code
# ==========================
.vscode/

# ==========================
# Configurações do Code::Blocks
# ==========================
*.layout
*.depend

# ==========================
# Configurações do Dev-C++
# ==========================
*.dev

# ==========================
# Configurações do Visual Studio
# ==========================
.vs/

# ==========================
# Cache
# ==========================
*.cache
